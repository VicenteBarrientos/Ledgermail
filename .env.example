# ------------------------------------------------------------------------------
# LedgerMail Environment Variables Configuration
# ------------------------------------------------------------------------------

# Database Connection (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ledgermail?schema=public"

# LLM Providers API Keys (Configure keys for the models you want to use)
OPENAI_API_KEY="your-openai-api-key-here"
GEMINI_API_KEY="your-gemini-api-key-here"
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# Google / Gmail OAuth Settings
GMAIL_CLIENT_ID="your-google-oauth-client-id-here"
GMAIL_CLIENT_SECRET="your-google-oauth-client-secret-here"
GMAIL_REDIRECT_URI="http://localhost:3000"

# Microsoft / Outlook / Hotmail OAuth (Azure app registration, tenant = common)
# Portal: https://portal.azure.com → App registrations → New registration
# Redirect URI (Web): http://localhost:3000
# API permissions: Microsoft Graph delegated — User.Read, Mail.Read, offline_access
OUTLOOK_CLIENT_ID="your-azure-application-client-id"
OUTLOOK_CLIENT_SECRET="your-azure-client-secret-value"
OUTLOOK_REDIRECT_URI="http://localhost:3000"

# Authentication Secrets
NEXTAUTH_SECRET="some-long-cryptographic-hash-here"

# API Service configurations
PORT=3001
CRON_SECRET="your-vercel-cron-authorization-secret"

# Feature Flags configurations (Set to "false" to disable)
ENABLE_AGGRESSIVE_SANITIZER=true
ENABLE_CACHE=true
ENABLE_RETRY=true
DEFAULT_LLM_PROVIDER=openai
DEFAULT_MODEL_NAME=gpt-4o-mini
ENABLE_PDF_EXTRACTION=true

# CondoSync Integration settings
CONDOSYNC_WEBHOOK_URL="http://localhost:4000/api/webhooks/payments"
# Same value as LEDGERMAIL_WEBHOOK_SECRET in CondoSync's Vercel env — sent as X-LedgerMail-Token.
CONDOSYNC_WEBHOOK_SECRET=""
API_BASE_URL="http://localhost:3001"

# ------------------------------------------------------------------------------
# Synthetic Canary (scripts/canary/run-canary.ts, npm run canary)
# Only needed to run the canary — not required for the app itself.
# ------------------------------------------------------------------------------

# A Gmail account + App Password (not OAuth) used just to SEND the test email.
# Create one at https://myaccount.google.com/apppasswords (requires 2FA enabled).
CANARY_SMTP_USER="canary-sender@gmail.com"
CANARY_SMTP_PASS="your-16-char-app-password"

# The monitored LedgerMail test inbox (already connected as a MailboxSource
# via the normal "Conectar Gmail" OAuth flow in the dashboard).
CANARY_TARGET_EMAIL="ledgermail-canary@gmail.com"
CANARY_MAILBOX_SOURCE_ID="the-mailboxsource-id-for-the-inbox-above"

# Optional: Slack (or any) incoming webhook URL, notified only on canary failure.
CANARY_ALERT_WEBHOOK_URL=""

