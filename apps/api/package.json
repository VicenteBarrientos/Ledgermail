{
  "name": "@ledgermail/api",
  "version": "1.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=api/index.js --external:@prisma/client && node scripts/copy-engines.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "@ledgermail/shared": "*",
    "@ledgermail/database": "*",
    "@ledgermail/core": "*",
    "@ledgermail/gmail": "*",
    "@ledgermail/providers": "*",
    "@prisma/client": "^5.10.2",
    "prisma": "^5.10.2"
  },
  "devDependencies": {
    "esbuild": "^0.20.1",
    "typescript": "^5.3.3",
    "tsx": "^4.7.1",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17"
  }
}
